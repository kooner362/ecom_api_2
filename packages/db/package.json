{
  "name": "@ecom/db",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "rm -rf dist tsconfig.tsbuildinfo && tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "prisma:generate": "set -a; [ -f ../../.env ] && . ../../.env; set +a; prisma generate --schema ./prisma/schema.prisma",
    "prisma:migrate": "set -a; [ -f ../../.env ] && . ../../.env; set +a; prisma migrate dev --schema ./prisma/schema.prisma",
    "prisma:studio": "set -a; [ -f ../../.env ] && . ../../.env; set +a; prisma studio --schema ./prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^6.4.1"
  },
  "devDependencies": {
    "prisma": "^6.4.1"
  }
}
